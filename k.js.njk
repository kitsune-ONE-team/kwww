---
# vim: set ft=javascript:
permalink: k.js
---

function crypto(name, address) {
    document.getElementById(`address-${name}`).innerHTML = address;
    const qrcode = document.getElementById(`qrcode-${name}`);
    new QRCode(qrcode, {
        text: address,
        width: 256,
        height: 256,
        colorDark: '#000000',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.H
    });
    qrcode.style.display = 'inline-block'; 
}

function init() {
    document.querySelectorAll('.k-menu .k-clickable').forEach(link => {
        if (link.getAttribute('href') === window.location.pathname) {
            link.classList.add('k-active');
        } else {
            link.classList.remove('k-active');
        }
    });

    const middle = document.getElementById('k-middle');
    if (window.location.pathname === '/k/' || window.location.pathname === '/k/index.html') {
        middle.classList.remove('k-compact');
    } else {
        middle.classList.add('k-compact');
    }

    if (window.location.pathname === '/k/donate/' || window.location.pathname === '/k/donate/index.html') {
        crypto('btc', 'bc1q8yv2qcxr9k7tx285pke3ywqz76m8rvap04rqnk');
        crypto('sol', 'AzQ47rcTVadNXoWhNbVvTj3UqkLPwrhh5cLT6YKVp96M');
    }
}

document.body.addEventListener('htmx:afterSwap', init);
init();
