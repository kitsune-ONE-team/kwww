<div id="k-content">
    <div class="k-section k-bg-dark">
        <h2 class="k-heading">Login with Steam</h2>

        <div class="k-form k-submitable k-bg-lighter k-hor-center">
            <p class="k-hor-center-inside">
                <img alt="Steam Logo" width="64" src="/image/logo/steam.png" />
            </p>
        </div>

        <div class="k-clear"></div>
    </div>
</div>

<script>
    var query = window.location.search;
    window.location = `{{config.api}}/steam/login/${query}`;
</script>
